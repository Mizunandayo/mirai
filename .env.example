# ── Backend (Gemini Developer API) ─────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
JWT_SECRET=your_secret_key_here
DATABASE_URL=sqlite:///./mirai.db

# ── Frontend direct Gemini (FASTEST — browser calls Gemini Developer API) ────
# Get a free key at: https://aistudio.google.com/app/apikey
# When set, the Tasks tab calls Gemini directly — NO backend round-trip.
# Reduces generation time from slower backend calls to 5-15 s.
# VITE_ prefix makes it available to Vite frontend code.
VITE_GEMINI_API_KEY=your_gemini_developer_api_key_here
